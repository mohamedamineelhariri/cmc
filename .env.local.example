# Base URL of the CMC backend API (FastAPI). The assistant streams from
# `${NEXT_PUBLIC_API_URL}/chatsystem/conversations/public/chat`.
#
# Local development (Docker backend on :8000):
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Production (Vercel): set this in the Vercel dashboard to your PUBLIC backend URL,
# e.g. a tunnel/host that exposes the FastAPI app over HTTPS.
# NEXT_PUBLIC_API_URL=https://api.votre-domaine.ma
